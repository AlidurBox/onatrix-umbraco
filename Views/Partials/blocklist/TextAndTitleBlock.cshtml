@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models
@using Umbraco.Extensions
@model BlockListItem

@{
    var content = Model.Content;

    string title = null;
    var rawObj = content.Value("textNTitle");
    if (rawObj is string single)
    {
        title = single;
    }
    else if (rawObj is IEnumerable<string> many)
    {
        title = many.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
    }

    if (!string.IsNullOrWhiteSpace(title) &&
        title.StartsWith("System.Collections", StringComparison.Ordinal))
    {
        title = null;
    }
}

@if (!string.IsNullOrWhiteSpace(title))
{
    <div style="max-width:1100px; margin:0 auto; padding:60px 20px;">
        <h2 style="font-size:32px; line-height:1.3; color:#1c2b39; margin:0;">@title</h2>
    </div>
}
