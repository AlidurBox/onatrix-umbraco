@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models
@using Umbraco.Extensions
@model BlockListItem

@{
    var content = Model.Content;
    var titel = content.Value<string>("titel") ?? "";
    var text = content.Value<string>("text") ?? "";
    var layout = content.Value<string>("layout") ?? "imageLeft";
    var media = content.Value<MediaWithCrops>("image");
    string imageUrl = media?.Url() ?? null;
}

<div style="max-width:1100px; margin:0 auto; padding:60px 20px;">
    <div style="display:flex; flex-direction:@(layout == "imageRight" ? "row-reverse" : "row"); gap:40px; align-items:center; flex-wrap:wrap;">
        <div style="flex:1; min-width:300px;">
            @if (!string.IsNullOrWhiteSpace(titel))
            {
                <h2 style="font-size:32px; font-weight:700; margin-bottom:20px; line-height:1.2;">@titel</h2>
            }
            @if (!string.IsNullOrWhiteSpace(text))
            {
                <div style="font-size:18px; line-height:1.8; color:#333;">
                    @Html.Raw(text)
                </div>
            }
        </div>
        <div style="flex:1; min-width:300px;">
            @if (imageUrl != null)
            {
                <img src="@imageUrl" style="width:100%; border-radius:12px; display:block;" alt="@media?.Name" />
            }
        </div>
    </div>
</div>
